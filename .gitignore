# We apply the Gitignore Whitelist approach here.
# Everything but a specific list of files and directories listed here gets ignored.
# 
# More on the approach: https://jasonstitt.com/gitignore-whitelisting-patterns.

# Ignore everything in the root folder:
/*

# Unignore a specific list of files in the root folder:
!/.gitignore
!/.gitmodules
!/LICENSE
!/README.md

# Unignore subtrees:
!/.github/
!/artifacts/
!/migrations/
!/queries/
!/types/
!/freeze1.pgn.yaml
!/project1.pgn.yaml

# Ignore noise:
Cargo.lock
.DS_Store
